# Agora Configuration
# Copy this file to .env and fill in your values.

# LiveKit Server
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Agent Configuration
# AGENT_NAME is set per-process at launch time
WHISPER_MODEL=small

# Per-agent TTS voices (format: EDGE_TTS_VOICE_{AGENTNAME})
# See https://learn.microsoft.com/en-us/azure/ai-services/speech-service/language-support
EDGE_TTS_VOICE_AGENT1=en-US-AriaNeural
EDGE_TTS_VOICE_AGENT2=en-US-GuyNeural

# LLM Backend: "anthropic" | "openai" | "ollama"
LLM_BACKEND=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
OLLAMA_MODEL=llama3.2:3b

# ACP Bridge (connects agents to their gateways via HTTP)
ACP_ENABLED=true
ACP_LAIRA_URL=http://127.0.0.1:3133
ACP_LOKI_URL=http://127.0.0.1:8642
ACP_STREAMING_AGENTS=laira,loki
ACP_API_KEY=

# ACP Event Bus (cross-session awareness)
ACP_BUS_HOST=0.0.0.0
ACP_BUS_PORT=9090
ACP_BUS_SECRET=
