LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# AI Agent config
AGENT_NAME=Laira
# Per-agent TTS voices: EDGE_TTS_VOICE_{NAME} takes priority over EDGE_TTS_VOICE
EDGE_TTS_VOICE_LAIRA=de-DE-SeraphinaMultilingualNeural
EDGE_TTS_VOICE_LOKI=en-US-GuyNeural
EDGE_TTS_VOICE=en-US-AriaNeural
WHISPER_MODEL=small

# LLM backend: "anthropic" | "openai-codex" | "openai" | "ollama"
LLM_BACKEND=anthropic
OLLAMA_MODEL=llama3.2:3b

# Anthropic (Claude) — OAuth token from Claude Code CLI ~/.claude/.credentials.json
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...

# OpenAI Codex — JWT from Codex CLI ~/.codex/auth.json (auto-read if not set)
OPENAI_MODEL=gpt-5.4

# ACP (Agent Communication Protocol) — direct HTTP streaming bridge to Hermes gateway
# Set to false to fall back to legacy docker-exec bridge (openclaw_bridge)
# NOTE: Laira runs Hermes (supports ACP). Loki runs OpenClaw (use ACP_ENABLED=false for Loki).
ACP_ENABLED=true
# Hermes API server URL (requires API_SERVER_ENABLED=true inside the Laira container)
ACP_LAIRA_URL=http://127.0.0.1:3133
# Loki doesn't run Hermes — leave this for future use when OpenClaw adds HTTP API
ACP_LOKI_URL=http://127.0.0.1:3143
# API key for the Hermes API server (leave empty if not configured)
ACP_API_KEY=
